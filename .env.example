# IgnitionRAG Community self-hosted distribution

DEPLOYMENT_MODE=self_hosted
IGNITION_EDITION=community
AUTH_PROVIDER=local
BILLING_PROVIDER=none
EMAIL_PROVIDER=none

IGNITION_VERSION=stable
IGNITION_API_IMAGE=ghcr.io/ignitionai/ignition-rag-api:stable
IGNITION_FRONT_IMAGE=ghcr.io/ignitionai/ignition-rag-front:stable
IGNITION_CRAWLER_IMAGE=ghcr.io/ignitionai/ignition-rag-crawler:stable
IGNITION_DOCUMENT_EXTRACTOR_IMAGE=ghcr.io/ignitionai/ignition-rag-document-extractor:stable

DATABASE_URL=postgresql://ignitionai:ignitionai@postgres:5432/ignitionai
POSTGRES_USER=ignitionai
POSTGRES_PASSWORD=ignitionai
POSTGRES_DB=ignitionai

ENCRYPTION_KEY=change-me-to-at-least-32-characters

SELF_HOSTED_ADMIN_USER_ID=selfhost_admin
SELF_HOSTED_BOOTSTRAP_EMAIL=admin@example.com
SELF_HOSTED_BOOTSTRAP_NAME=Community Admin
SELF_HOSTED_BOOTSTRAP_PASSWORD=change-me-before-first-login
SELF_HOSTED_ORG_ID=selfhost_org
SELF_HOSTED_ORG_NAME=Community Workspace
SELF_HOSTED_ORG_SLUG=community-workspace
LOCAL_SESSION_TTL_SECONDS=43200

OPENAI_API_KEY=
JINA_API_KEY=
EMBEDDING_PROVIDER=openai

QDRANT_URL=http://qdrant:6333
QDRANT_PUBLIC_URL=http://localhost:6333
QDRANT_LOCAL=true

S3_ENABLED=true
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ignition-rag-storage

BACKUP_DIR=./backups
IGNITION_RELEASE_PUBLIC_KEY=jjz5hC2y/svweN9UfMhRyAau/otEOnlInhIvuQuo8Gw=
